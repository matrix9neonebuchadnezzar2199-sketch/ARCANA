{
  "name": "@arcana/mcp-server",
  "version": "0.1.0",
  "description": "ARCANA MCP Server - Natural language bridge for Unity, Unreal Engine and Blender",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "tsc --watch",
    "lint": "eslint src/",
    "test": "jest"
  },
  "keywords": [
    "mcp",
    "unity",
    "unreal-engine",
    "blender",
    "ai",
    "natural-language",
    "model-context-protocol",
    "arcana"
  ],
  "author": "ARCANA Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matrix9neonebuchadnezzar2199-sketch/ARCANA.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^10.0.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.57.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  }
}
